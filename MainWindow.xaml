<Window x:Class="CybersecurityChatBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot - Cybersecurity Awareness Chatbot"
        Height="700" Width="1000"
        MinHeight="500" MinWidth="750"
        Background="#808080"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ROW 0 - Header -->
        <Border Grid.Row="0"
                Background="#A9A9A9"
                BorderBrush="#000000"
                BorderThickness="0,0,0,2"
                Padding="15,10">
            <StackPanel>
                <TextBlock x:Name="AsciiArtDisplay"
                           FontFamily="Courier New"
                           FontSize="11"
                           Foreground="#000000"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="╔══════════════════════════════════════════════════════╗"
                           FontFamily="Courier New" FontSize="12" Foreground="#000000"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="║        CYBERSECURITY AWARENESS CHATBOT              ║"
                           FontFamily="Courier New" FontSize="12" Foreground="#000000"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="╚══════════════════════════════════════════════════════╝"
                           FontFamily="Courier New" FontSize="12" Foreground="#000000"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ROW 1 - TabControl -->
        <TabControl Grid.Row="1" Background="#808080" BorderThickness="0">

            <!-- ═══ TAB 1: CHAT ═══ -->
            <TabItem Header="💬 Chat" FontFamily="Courier New" FontSize="13">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer x:Name="ChatScrollViewer"
                                  Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="#808080"
                                  Padding="10">
                        <TextBlock x:Name="ChatDisplay"
                                   FontFamily="Courier New"
                                   FontSize="13"
                                   Foreground="#000000"
                                   TextWrapping="Wrap"
                                   Padding="10"
                                   LineHeight="22"/>
                    </ScrollViewer>

                    <Border Grid.Row="1"
                            Background="#A9A9A9"
                            BorderBrush="#000000"
                            BorderThickness="0,2,0,0"
                            Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="UserInput"
                                     Grid.Column="0"
                                     Height="40"
                                     FontFamily="Courier New"
                                     FontSize="13"
                                     Foreground="#000000"
                                     Background="#D3D3D3"
                                     BorderBrush="#000000"
                                     BorderThickness="1"
                                     Padding="8,8"
                                     CaretBrush="#000000"
                                     Margin="0,0,10,0"
                                     VerticalContentAlignment="Center"
                                     KeyDown="UserInput_KeyDown"/>
                            <Button x:Name="SendButton"
                                    Grid.Column="1"
                                    Content="SEND ▶"
                                    Width="90" Height="40"
                                    FontFamily="Courier New"
                                    FontSize="12" FontWeight="Bold"
                                    Foreground="#000000"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="SendButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#A9A9A9"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#808080"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 2: TASK ASSISTANT ═══ -->
            <TabItem Header="📋 Tasks" FontFamily="Courier New" FontSize="13">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Add Task Form -->
                    <Border Grid.Column="0"
                            Background="#A9A9A9"
                            BorderBrush="#000000"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="ADD NEW TASK"
                                       FontFamily="Courier New"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#000000"
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="Title:" FontFamily="Courier New" FontSize="12" Foreground="#000000"/>
                            <TextBox x:Name="TaskTitleInput"
                                     Height="30" Margin="0,3,0,8"
                                     FontFamily="Courier New" FontSize="12"
                                     Background="#D3D3D3" BorderBrush="#000000"
                                     Padding="5,5"/>

                            <TextBlock Text="Description:" FontFamily="Courier New" FontSize="12" Foreground="#000000"/>
                            <TextBox x:Name="TaskDescriptionInput"
                                     Height="60" Margin="0,3,0,8"
                                     FontFamily="Courier New" FontSize="12"
                                     Background="#D3D3D3" BorderBrush="#000000"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     Padding="5,5"/>

                            <TextBlock Text="Reminder (optional):" FontFamily="Courier New" FontSize="12" Foreground="#000000"/>
                            <TextBox x:Name="TaskReminderInput"
                                     Height="30" Margin="0,3,0,12"
                                     FontFamily="Courier New" FontSize="12"
                                     Background="#D3D3D3" BorderBrush="#000000"
                                     Padding="5,5"/>

                            <Button x:Name="AddTaskButton"
                                    Content="+ ADD TASK"
                                    Height="35"
                                    FontFamily="Courier New"
                                    FontSize="12" FontWeight="Bold"
                                    Foreground="#000000"
                                    Background="#D3D3D3"
                                    BorderBrush="#000000"
                                    Cursor="Hand"
                                    Click="AddTaskButton_Click"/>

                            <TextBlock x:Name="TaskStatusText"
                                       FontFamily="Courier New"
                                       FontSize="11"
                                       Foreground="#000000"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Right: Task List -->
                    <Border Grid.Column="1"
                            Background="#A9A9A9"
                            BorderBrush="#000000"
                            BorderThickness="1"
                            Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="CURRENT TASKS"
                                       FontFamily="Courier New"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#000000"
                                       Margin="0,0,0,10"/>

                            <ListBox x:Name="TaskListBox"
                                     Grid.Row="1"
                                     FontFamily="Courier New"
                                     FontSize="12"
                                     Background="#D3D3D3"
                                     BorderBrush="#000000"
                                     Margin="0,0,0,10"
                                     DisplayMemberPath="Display"/>

                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                <Button x:Name="MarkCompleteButton"
                                        Content="✔ COMPLETE"
                                        Width="110" Height="35"
                                        FontFamily="Courier New"
                                        FontSize="11" FontWeight="Bold"
                                        Foreground="#000000"
                                        Background="#D3D3D3"
                                        BorderBrush="#000000"
                                        Cursor="Hand"
                                        Margin="0,0,10,0"
                                        Click="MarkCompleteButton_Click"/>
                                <Button x:Name="DeleteTaskButton"
                                        Content="🗑 DELETE"
                                        Width="100" Height="35"
                                        FontFamily="Courier New"
                                        FontSize="11" FontWeight="Bold"
                                        Foreground="#000000"
                                        Background="#D3D3D3"
                                        BorderBrush="#000000"
                                        Cursor="Hand"
                                        Click="DeleteTaskButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 3: QUIZ ═══ -->
            <TabItem Header="🎯 Quiz" FontFamily="Courier New" FontSize="13">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Score tracker -->
                    <TextBlock x:Name="QuizScoreText"
                               Grid.Row="0"
                               Text="Score: 0"
                               FontFamily="Courier New"
                               FontSize="13" FontWeight="Bold"
                               Foreground="#000000"
                               HorizontalAlignment="Right"
                               Margin="0,0,0,10"/>

                    <!-- Question -->
                    <Border Grid.Row="1"
                            Background="#A9A9A9"
                            BorderBrush="#000000"
                            BorderThickness="1"
                            Padding="15"
                            Margin="0,0,0,15">
                        <TextBlock x:Name="QuizQuestionText"
                                   Text="Press 'Start Quiz' to begin!"
                                   FontFamily="Courier New"
                                   FontSize="14"
                                   Foreground="#000000"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Answer options -->
                    <StackPanel x:Name="QuizOptionsPanel" Grid.Row="2" Margin="0,0,0,10">
                        <RadioButton x:Name="QuizOption1" FontFamily="Courier New" FontSize="13"
                                     Foreground="#000000" Margin="0,5" GroupName="QuizOptions"/>
                        <RadioButton x:Name="QuizOption2" FontFamily="Courier New" FontSize="13"
                                     Foreground="#000000" Margin="0,5" GroupName="QuizOptions"/>
                        <RadioButton x:Name="QuizOption3" FontFamily="Courier New" FontSize="13"
                                     Foreground="#000000" Margin="0,5" GroupName="QuizOptions"/>
                        <RadioButton x:Name="QuizOption4" FontFamily="Courier New" FontSize="13"
                                     Foreground="#000000" Margin="0,5" GroupName="QuizOptions"/>
                    </StackPanel>

                    <!-- Feedback -->
                    <Border Grid.Row="3"
                            Background="#D3D3D3"
                            BorderBrush="#000000"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,0,10">
                        <TextBlock x:Name="QuizFeedbackText"
                                   FontFamily="Courier New"
                                   FontSize="12"
                                   Foreground="#000000"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="StartQuizButton"
                                Content="▶ START QUIZ"
                                Width="120" Height="35"
                                FontFamily="Courier New"
                                FontSize="12" FontWeight="Bold"
                                Foreground="#000000"
                                Background="#D3D3D3"
                                BorderBrush="#000000"
                                Cursor="Hand"
                                Margin="0,0,10,0"
                                Click="StartQuizButton_Click"/>
                        <Button x:Name="SubmitAnswerButton"
                                Content="✔ SUBMIT"
                                Width="100" Height="35"
                                FontFamily="Courier New"
                                FontSize="12" FontWeight="Bold"
                                Foreground="#000000"
                                Background="#D3D3D3"
                                BorderBrush="#000000"
                                Cursor="Hand"
                                Margin="0,0,10,0"
                                IsEnabled="False"
                                Click="SubmitAnswerButton_Click"/>
                        <Button x:Name="NextQuestionButton"
                                Content="NEXT ▶"
                                Width="100" Height="35"
                                FontFamily="Courier New"
                                FontSize="12" FontWeight="Bold"
                                Foreground="#000000"
                                Background="#D3D3D3"
                                BorderBrush="#000000"
                                Cursor="Hand"
                                Visibility="Collapsed"
                                Click="NextQuestionButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 4: ACTIVITY LOG ═══ -->
            <TabItem Header="📜 Activity Log" FontFamily="Courier New" FontSize="13">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="ACTIVITY LOG"
                               FontFamily="Courier New"
                               FontSize="14" FontWeight="Bold"
                               Foreground="#000000"
                               Margin="0,0,0,10"/>

                    <Border Grid.Row="1"
                            Background="#D3D3D3"
                            BorderBrush="#000000"
                            BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="ActivityLogDisplay"
                                       FontFamily="Courier New"
                                       FontSize="12"
                                       Foreground="#000000"
                                       TextWrapping="Wrap"
                                       Padding="10"/>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button x:Name="RefreshLogButton"
                                Content="🔄 REFRESH LOG"
                                Width="140" Height="35"
                                FontFamily="Courier New"
                                FontSize="12" FontWeight="Bold"
                                Foreground="#000000"
                                Background="#D3D3D3"
                                BorderBrush="#000000"
                                Cursor="Hand"
                                Margin="0,0,10,0"
                                Click="RefreshLogButton_Click"/>
                        <Button x:Name="ShowMoreLogButton"
                                Content="SHOW MORE"
                                Width="120" Height="35"
                                FontFamily="Courier New"
                                FontSize="12" FontWeight="Bold"
                                Foreground="#000000"
                                Background="#D3D3D3"
                                BorderBrush="#000000"
                                Cursor="Hand"
                                Visibility="Collapsed"
                                Click="ShowMoreLogButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ROW 2 - Status Bar -->
        <Border Grid.Row="2"
                Background="#A9A9A9"
                BorderBrush="#000000"
                BorderThickness="0,2,0,0"
                Padding="10,5">
            <TextBlock x:Name="StatusBar"
                       Text="Ready"
                       FontFamily="Courier New"
                       FontSize="11"
                       Foreground="#000000"/>
        </Border>

    </Grid>
</Window>